<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/FishBalatro/UI/HighScoreUI.uss?fileID=7433441132597879392&amp;guid=09c2f4f9661adcf428842f484767d3d6&amp;type=3#HighScoreUI"/>
    <ui:VisualElement name="high-score-root" style="flex-grow: 1; height: 100%; background-image: url(&quot;project://database/Assets/FishBalatro/Art/Backgrounds/caught_bg.png?fileID=2800000&amp;guid=6e50ac497f6e80c409df1da5b47a5a90&amp;type=3#caught_bg&quot;);">
        <ui:VisualElement name="high-score-panel" style="flex-grow: 1; background-image: none; align-self: center; height: 100%; padding-top: 55px; margin-right: -1px; top: 25px; margin-top: 0; padding-bottom: 164px; align-content: flex-start; justify-content: center; align-items: center;">
            <ui:Label text="Highest Scores" name="high-score-title" style="top: 15px; bottom: -10px; -unity-font-definition: url(&quot;project://database/Assets/FishBalatro/Font/Malam%20Poek.otf?fileID=12800000&amp;guid=d18ffa7593a13864f802c41f0f8e3a3d&amp;type=3#Malam Poek&quot;); color: rgb(255, 220, 80); -unity-text-outline-width: 2px; -unity-text-outline-color: rgb(8, 42, 58);"/>
            <ui:Label text="1." name="score-1" style="top: 20px; -unity-font-definition: url(&quot;project://database/Assets/FishBalatro/Font/Malam%20Poek.otf?fileID=12800000&amp;guid=d18ffa7593a13864f802c41f0f8e3a3d&amp;type=3#Malam Poek&quot;); height: 34px; -unity-text-outline-width: 2px; -unity-text-outline-color: rgb(8, 42, 58);"/>
            <ui:Label text="2." name="score-2" style="top: 20px; -unity-font-definition: url(&quot;project://database/Assets/FishBalatro/Font/Malam%20Poek.otf?fileID=12800000&amp;guid=d18ffa7593a13864f802c41f0f8e3a3d&amp;type=3#Malam Poek&quot;); -unity-text-outline-width: 2px; -unity-text-outline-color: rgb(8, 42, 58);"/>
            <ui:Label text="3." name="score-3" style="top: 20px; -unity-font-definition: url(&quot;project://database/Assets/FishBalatro/Font/Malam%20Poek.otf?fileID=12800000&amp;guid=d18ffa7593a13864f802c41f0f8e3a3d&amp;type=3#Malam Poek&quot;); -unity-text-outline-width: 2px; -unity-text-outline-color: rgb(8, 42, 58);"/>
            <ui:Label text="4." name="score-4" style="top: 15px; -unity-font-definition: url(&quot;project://database/Assets/FishBalatro/Font/Malam%20Poek.otf?fileID=12800000&amp;guid=d18ffa7593a13864f802c41f0f8e3a3d&amp;type=3#Malam Poek&quot;); -unity-text-outline-width: 2px; -unity-text-outline-color: rgb(8, 42, 58);"/>
            <ui:Label text="5." name="score-5" style="top: 10px; -unity-font-definition: url(&quot;project://database/Assets/FishBalatro/Font/Malam%20Poek.otf?fileID=12800000&amp;guid=d18ffa7593a13864f802c41f0f8e3a3d&amp;type=3#Malam Poek&quot;); -unity-text-outline-width: 2px; -unity-text-outline-color: rgb(8, 42, 58);"/>
            <ui:VisualElement name="button-row" style="flex-grow: 1; height: 20px; align-self: auto; align-content: flex-start; justify-content: center; align-items: center; flex-direction: row; width: 384px; padding-top: 0; padding-left: 0; top: 33px;">
                <ui:Button text="Back" name="back-button" style="-unity-font-definition: url(&quot;project://database/Assets/FishBalatro/Font/Malam%20Poek.otf?fileID=12800000&amp;guid=d18ffa7593a13864f802c41f0f8e3a3d&amp;type=3#Malam Poek&quot;); -unity-text-outline-color: rgb(8, 42, 58); -unity-text-outline-width: 2px;"/>
